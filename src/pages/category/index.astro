---
import Layout from '../../layouts/Layout.astro'
import { categories } from '../../lib/mock-data'
---

<Layout title="全部分类 — AI 工具导航">
  <section class="mx-auto max-w-7xl px-4 py-8">
    <nav class="flex text-sm text-gray-500">
      <a href="/" class="hover:text-indigo-600">首页</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">全部分类</span>
    </nav>
  </section>

  <section class="mx-auto max-w-7xl px-4 pb-16">
    <h1 class="mb-8 text-3xl font-bold text-gray-900">全部分类</h1>
    <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="group flex flex-col items-center rounded-xl border border-gray-200 bg-white p-6 text-center transition hover:border-indigo-200 hover:shadow-lg"
        >
          <span class="text-4xl">{cat.icon}</span>
          <h2 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-indigo-600">{cat.name}</h2>
          <p class="mt-1 text-sm text-gray-500">{cat.toolCount} 个工具</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
