---
import Layout from '../layouts/Layout.astro'
import ToolCard from '../components/ToolCard.astro'
import { categories, getFeaturedTools } from '../lib/mock-data'

const featured = getFeaturedTools()
const activeCategories = categories.filter(c => c.toolCount > 0)
---

<Layout title="首页 — 发现最好的 AI 工具">
  <!-- Hero -->
  <section class="mx-auto max-w-7xl px-4 py-16 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl">
      发现最好的 <span class="bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent">AI 工具</span>
    </h1>
    <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-600">
      精选优质 AI 工具，分类浏览、搜索筛选、评分收藏 — 一站搞定。
    </p>
    <div class="mt-8 flex justify-center">
      <div class="relative w-full max-w-xl">
        <svg class="absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          type="text"
          placeholder="搜索 AI 工具..."
          class="w-full rounded-xl border border-gray-300 py-3 pl-12 pr-4 text-lg shadow-sm transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-200"
        />
      </div>
    </div>
    <div class="mt-4 flex flex-wrap justify-center gap-2 text-sm text-gray-500">
      <span>热门:</span>
      {activeCategories.slice(0, 5).map((cat) => (
        <a href={`/category/${cat.slug}`} class="rounded-full bg-gray-100 px-3 py-1 hover:bg-indigo-50 hover:text-indigo-600">
          {cat.icon} {cat.name}
        </a>
      ))}
    </div>
  </section>

  <!-- Categories -->
  <section class="mx-auto max-w-7xl px-4 pb-12">
    <h2 class="mb-6 text-2xl font-semibold text-gray-900">📂 分类浏览</h2>
    <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {categories.map((cat) => (
        <a
          href={`/category/${cat.slug}`}
          class="flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 transition hover:border-indigo-200 hover:shadow-md"
        >
          <span class="text-2xl">{cat.icon}</span>
          <div>
            <div class="font-medium text-gray-900">{cat.name}</div>
            <div class="text-sm text-gray-500">{cat.toolCount} 个工具</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="mx-auto max-w-7xl px-4 pb-16">
    <div class="mb-6 flex items-center justify-between">
      <h2 class="text-2xl font-semibold text-gray-900">🔥 精选工具</h2>
      <a href="/category" class="text-sm text-indigo-600 hover:text-indigo-700">查看全部 →</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((tool) => (
        <ToolCard
          name={tool.name}
          descriptionShort={tool.descriptionShort}
          url={`/tool/${tool.slug}`}
          logoUrl={tool.logoUrl}
          pricingModel={tool.pricingModel}
          categoryPrimary={tool.categoryPrimary}
          chineseSupport={tool.chineseSupport}
          tags={tool.tags}
          editorScore={tool.editorScore}
        />
      ))}
    </div>
  </section>
</Layout>
