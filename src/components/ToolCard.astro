---
interface Props {
  name: string
  description: string
  url: string
  logoUrl?: string
  pricing: string
  category: string
  tags?: string[]
}

const { name, description, url, logoUrl, pricing, category, tags = [] } = Astro.props

const pricingColors: Record<string, string> = {
  free: 'text-green-600 bg-green-50',
  freemium: 'text-blue-600 bg-blue-50',
  paid: 'text-orange-600 bg-orange-50',
  open_source: 'text-purple-600 bg-purple-50',
}

const pricingLabels: Record<string, string> = {
  free: '免费',
  freemium: '免费增值',
  paid: '付费',
  open_source: '开源',
}
---

<a href={url} target="_blank" rel="noopener" class="group block rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:shadow-md hover:border-indigo-200">
  <div class="mb-3 flex items-center gap-3">
    {logoUrl ? (
      <img src={logoUrl} alt={name} class="h-10 w-10 rounded-lg object-cover" />
    ) : (
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-100 text-lg font-bold text-indigo-600">
        {name.charAt(0)}
      </div>
    )}
    <div class="flex-1">
      <h3 class="font-semibold text-gray-900 group-hover:text-indigo-600">{name}</h3>
      <span class={`inline-block rounded-full px-2 py-0.5 text-xs font-medium ${pricingColors[pricing] || 'text-gray-600 bg-gray-50'}`}>
        {pricingLabels[pricing] || pricing}
      </span>
    </div>
  </div>
  <p class="mb-3 text-sm text-gray-600 line-clamp-2">{description}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.slice(0, 3).map((tag) => (
        <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-500">{tag}</span>
      ))}
    </div>
  )}
</a>
